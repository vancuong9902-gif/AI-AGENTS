# =============================
# AI-AGENTS canonical env template
# =============================
# Usage (Docker Compose):
#   cp .env.example backend/.env
#   docker compose up --build -d

# ---------- Core ----------
ENV=dev
APP_NAME=AI Learning Agent

# ---------- Database / Queue ----------
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ai_agent
REDIS_URL=redis://redis:6379/0
ASYNC_QUEUE_ENABLED=true

# ---------- Auth ----------
AUTH_ENABLED=true
JWT_SECRET_KEY=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# ---------- API / CORS ----------
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
MAX_UPLOAD_MB=20
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ---------- LLM Provider (OpenAI-compatible) ----------
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=openai-gpt-oss-20b
OPENAI_JSON_MODEL=
OPENAI_REASONING_EFFORT=none

# ---------- Optional Azure OpenAI ----------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ---------- AI Mode Controls ----------
QUIZ_GEN_MODE=auto
LESSON_GEN_MODE=auto
SEMANTIC_RAG_ENABLED=false

# ---------- Topic / Learning Plan ----------
TOPIC_MAX_TOPICS=60
TOPIC_MIN_BODY_CHARS=2200
TOPIC_HIDE_APPENDIX=true
LEARNING_PLAN_MODE=auto
LEARNING_PLAN_DAYS=7
LEARNING_PLAN_MINUTES_PER_DAY=35

# ---------- Essay / Homework ----------
ESSAY_AUTO_GRADE=always
ESSAY_AUTO_GRADE_MIN_CHARS=40
HOMEWORK_AUTO_GRADE=always
HOMEWORK_MIN_CHARS=40

# ---------- OCR / PDF ----------
PDF_OCR_ENABLED=true
PDF_OCR_LANG=vie+eng
PDF_OCR_MAX_PAGES=200
PDF_OCR_ZOOM=2.5
PDF_EXTRACT_MIN_QUALITY_SCORE=0.35

# ---------- Worker ----------
RQ_DEFAULT_TIMEOUT_SEC=1800

# ---------- Demo ----------
DEMO_SEED=false

# ---------- AI LMS Node stack (optional) ----------
ANTHROPIC_API_KEY=your_anthropic_key_here
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d
PORT=3001
FRONTEND_URL=http://localhost:5173
MAX_PDF_SIZE_MB=50
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
NODE_ENV=development
