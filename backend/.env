ENV=dev
APP_NAME=AI Learning Agent
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ai_agent
REDIS_URL=redis://redis:6379/0
ASYNC_QUEUE_ENABLED=true
AUTH_ENABLED=true
JWT_SECRET_KEY=2535c888cc49fe831f51e6f87c5818a9cf82325259c638dc67004ac67b0ba04f
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@demo.local
ADMIN_PASSWORD=Admin@123456
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://frontend:5173"]
MAX_UPLOAD_MB=20
RATE_LIMIT_REQUESTS_PER_MINUTE=60
OPENAI_API_KEY=
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_CHAT_MODEL=qwen2.5:7b
OPENAI_EMBED_MODEL=nomic-embed-text
OPENAI_JSON_MODEL=
OPENAI_REASONING_EFFORT=none
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
QUIZ_GEN_MODE=auto
LESSON_GEN_MODE=auto
SEMANTIC_RAG_ENABLED=false
TOPIC_MAX_TOPICS=60
TOPIC_MIN_BODY_CHARS=2200
TOPIC_HIDE_APPENDIX=true
LEARNING_PLAN_MODE=auto
LEARNING_PLAN_DAYS=7
LEARNING_PLAN_MINUTES_PER_DAY=35
ESSAY_AUTO_GRADE=always
ESSAY_AUTO_GRADE_MIN_CHARS=40
HOMEWORK_AUTO_GRADE=always
HOMEWORK_MIN_CHARS=40
PDF_OCR_ENABLED=true
PDF_OCR_LANG=vie+eng
PDF_OCR_MAX_PAGES=200
PDF_OCR_ZOOM=2.5
PDF_EXTRACT_MIN_QUALITY_SCORE=0.35
RQ_DEFAULT_TIMEOUT_SEC=1800
DEMO_SEED=true
